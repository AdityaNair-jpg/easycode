{
  "name": "@easycode/server",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "postinstall": "bun run --cwd ../database db:generate"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.79",
    "@ai-sdk/google": "^2.0.30",
    "@ai-sdk/openai": "^3.0.65",
    "@clerk/backend": "^3.4.14",
    "@easycode/database": "workspace:*",
    "@easycode/shared": "workspace:*",
    "@hono/clerk-auth": "^3.1.1",
    "@hono/zod-validator": "^0.8.0",
    "@sentry/bun": "^10.53.1",
    "@sentry/hono": "^10.53.1",
    "ai": "^6.0.191",
    "dotenv": "^17.4.2",
    "hono": "^4.12.22",
    "zod": "^4.4.3"
  }
}
